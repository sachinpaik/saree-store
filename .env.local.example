NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# App-owned auth (JWT session); use a long random string (e.g. openssl rand -base64 32)
AUTH_SECRET=your_secret_at_least_32_chars_long

# Storage (media streaming via /api/media/[...key])
STORAGE_PROVIDER=supabase
SUPABASE_STORAGE_BUCKET=product-images
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# For local storage provider
# LOCAL_STORAGE_DIR=./storage

# For Cloudflare R2 storage provider
# CLOUDFLARE_R2_ACCOUNT_ID=your_account_id
# CLOUDFLARE_R2_ACCESS_KEY_ID=your_access_key_id
# CLOUDFLARE_R2_SECRET_ACCESS_KEY=your_secret_access_key
# CLOUDFLARE_R2_BUCKET=your_bucket_name
# CLOUDFLARE_R2_PUBLIC_BASE_URL=https://cdn.example.com (optional)

# Temp upload cleanup
# Time-to-live for temporary uploads in hours (default: 24)
# Files older than this will be deleted by cleanup script
TEMP_UPLOAD_TTL_HOURS=24

# Cache headers for media route
# MEDIA_CACHE_IMMUTABLE_SECONDS=31536000
# MEDIA_CACHE_DEFAULT_SECONDS=3600
